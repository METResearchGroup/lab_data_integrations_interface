# ==============================================================================
# OpenTelemetry & Grafana Configuration Template
# ==============================================================================

# The service name that will identify this application in Grafana
OTEL_SERVICE_NAME=backend

# The protocol used to transmit telemetry data. Grafana Cloud requires http/protobuf.
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Base gateway URL for Grafana Cloud. Replace <region> with your actual region (e.g., us-central-0).
# Note: Do not append signal paths like /v1/traces; the SDK handles this automatically.
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-<region>.grafana.net/otlp

# Authentication header. Format must be: Authorization=Basic%20<base64_encoded_string>
# Note: The space must be URL-encoded as '%20' or the Python exporter will fail.
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20<PLACEHOLDER_BASE64_INSTANCE_ID_COLON_TOKEN>

# ==============================================================================
# Railway / Infrastructure Configuration
# ==============================================================================

# AWS Credentials
# Required for Athena and S3 operations (e.g., in data_platform/aws/ and backend/routes/posts.py).
# Note: Locally, these are usually read from ~/.aws, but they must be explicitly set on Railway.
AWS_ACCESS_KEY_ID=<your_aws_access_key_id>
AWS_SECRET_ACCESS_KEY=<your_aws_secret_access_key>

# AWS Session Token
# OPTIONAL: Only uncomment and provide this if you are using temporary/STS credentials.
# Leave blank or commented out if you are using a long-lived IAM user's static keys.
# AWS_SESSION_TOKEN=<your_temporary_session_token>

# Security / CORS Configuration
# Comma-separated list of allowed origins parsed by backend/main.py.
# In production on Railway, set this to your deployed frontend's URL (e.g., https://my-app.vercel.app).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==============================================================================
# Supabase Auth Configuration
# ==============================================================================

# Project URL — also used to derive the JWKS endpoint for verifying JWTs
# (https://<ref>.supabase.co/auth/v1/.well-known/jwks.json).
# See docs/runbooks/HOW_TO_ADD_SUPABASE_AUTH.md
SUPABASE_URL=https://<your-project-ref>.supabase.co



